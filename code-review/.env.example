# Required for running the code review agents locally
# Get your key at: https://console.anthropic.com
# See README.md for full local usage instructions

ANTHROPIC_API_KEY=sk-ant-...

# Required when running locally (set automatically in GitHub Actions)
REPO_ROOT=/absolute/path/to/repo

# The base commit SHA to diff against (e.g. the merge-base of the PR)
BASE_REF=main

# The head commit SHA to review (defaults to HEAD if not set)
HEAD_REF=HEAD

# PR number — used only for the report filename (optional locally)
PR_NUMBER=manual
