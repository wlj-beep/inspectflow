# InspectFlow on-prem environment defaults
NODE_ENV=production

# Runtime ports
BACKEND_PORT=4000
FRONTEND_PORT=4173
FRONTEND_HOST=0.0.0.0

# PostgreSQL connections
DATABASE_URL=postgres://postgres@localhost:5432/inspectflow
DATABASE_URL_TEST=postgres://postgres@localhost:5432/inspectflow_test

# Auth/session controls
INSPECTFLOW_DEFAULT_PASSWORD=inspectflow
AUTH_SESSION_TTL_HOURS=12
AUTH_COOKIE_SECURE=false
ALLOW_LEGACY_ROLE_HEADER=false

# Backup defaults
BACKUP_ROOT=var/backups
BACKUP_RETENTION_DAYS=14

# Install/start behavior
INSPECTFLOW_SEED_ON_INSTALL=true

# Offline update bundle signing (BL-020)
# Preferred: point to a local file that contains only the signing key.
INSPECTFLOW_UPDATE_SIGNING_KEY_FILE=
# Fallback: inline key value (leave empty if using key file).
INSPECTFLOW_UPDATE_SIGNING_KEY=
# Minimum free disk required by preflight before applying update.
UPDATE_MIN_FREE_MB=1024
# If true, apply step runs npm install commands before migrate/build.
INSPECTFLOW_UPDATE_RUN_INSTALL=false
