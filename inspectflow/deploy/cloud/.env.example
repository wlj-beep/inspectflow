# Cloud baseline starter variables
# Copy to a local env file or export these values before running docker compose.

NODE_ENV=production

# Public ingress and TLS
CLOUD_CADDY_SITE=:80
CLOUD_PUBLIC_ORIGIN=http://localhost:8080
CLOUD_TLS_EMAIL=ops@example.com
CLOUD_HTTP_PORT=8080
CLOUD_HTTPS_PORT=8443
# For real TLS, switch CLOUD_CADDY_SITE to your public hostname and publish 80/443 instead of 8080/8443.

# Application runtime
BACKEND_PORT=4000
POSTGRES_DB=inspectflow
POSTGRES_USER=inspectflow
POSTGRES_PASSWORD=change-me
AUTH_TOKEN_PEPPER=change-me-too
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_HOURS=12
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
INSPECTFLOW_DEFAULT_PASSWORD=inspectflow
INSPECTFLOW_SEED_ON_INSTALL=true

# Backup retention
BACKUP_RETENTION_DAYS=14
