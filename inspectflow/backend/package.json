{
  "name": "inspectflow-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "db:migrate": "node src/scripts/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "db:migrate:test": "NODE_ENV=test node src/scripts/migrate.js",
    "db:seed:test": "NODE_ENV=test node src/scripts/seed.js",
    "db:test:setup": "npm run db:migrate:test && npm run db:seed:test",
    "test": "NODE_ENV=test npm run db:test:setup && NODE_ENV=test vitest run --poolOptions.threads.singleThread --no-file-parallelism"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "superagent": "^10.3.0",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
