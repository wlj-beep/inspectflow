{
  "name": "inspectflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "coordination:check": "node scripts/validate-coordination.mjs",
    "test": "npm run test:api && npm run test:ui",
    "context:budget": "node scripts/context/enforce-context-budget.mjs",
    "ops:cycle:report": "node scripts/operations/generate-cycle-report.mjs",
    "ops:cycle:report:auto": "node scripts/operations/generate-cycle-report.mjs --usageDir docs/operations/cycles/evidence",
    "test:coordination": "npm run coordination:check && npm run context:budget",
    "test:api": "npm run test --prefix backend",
    "test:ui": "npm run test:ui --prefix frontend",
    "test:ui:mock": "npm run test:ui --prefix frontend -- --grep @mock",
    "test:ui:live": "bash scripts/run-ui-live-tests.sh",
    "test:standardized": "npm run test:coordination && npm run test:api && npm run test:ui:mock && npm run test:ui:live",
    "test:load:commercialization": "bash scripts/load/test-commercialization-load-gate.sh",
    "test:release:commercialization:rc": "bash scripts/release/test-commercialization-rc-gate.sh",
    "gate:commercialization:load": "bash scripts/load/run-commercialization-load-gate.sh",
    "gate:commercialization:rc": "bash scripts/release/run-commercialization-rc-gate.sh",
    "release:path": "bash scripts/release/run-release-path.sh",
    "db:test:setup": "npm run db:test:setup --prefix backend",
    "deploy:onprem:install": "bash deploy/onprem/install.sh",
    "deploy:onprem:start": "bash deploy/onprem/start.sh",
    "deploy:onprem:stop": "bash deploy/onprem/stop.sh",
    "deploy:onprem:health": "bash deploy/onprem/healthcheck.sh",
    "deploy:onprem:rollback": "bash deploy/onprem/rollback.sh",
    "deploy:onprem:update:bundle:create": "bash deploy/onprem/create-update-bundle.sh",
    "deploy:onprem:update:bundle:verify": "bash deploy/onprem/verify-update-bundle.sh",
    "deploy:onprem:update:preflight": "bash deploy/onprem/preflight-update.sh",
    "deploy:onprem:update:apply": "bash deploy/onprem/apply-update-bundle.sh",
    "backup:create": "bash scripts/backup/backup.sh",
    "backup:restore": "bash scripts/backup/restore.sh",
    "backup:verify": "bash scripts/backup/verify-restore.sh",
    "backup:run-scheduled": "bash scripts/backup/run-scheduled-backup.sh"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
